{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InterviewPlan",
  "type": "object",
  "properties": {
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "role": { "type": "string" },
                "follow_ups": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "required": ["id", "text", "role"]
            }
          },
          "exit_criteria": { "type": "string" }
        },
        "required": ["name", "questions"]
      }
    },
    "rubric": {
      "type": "object",
      "properties": {
        "competencies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "weight": { "type": "number" }
            },
            "required": ["name", "description", "weight"]
          }
        }
      },
      "required": ["competencies"]
    }
  },
  "required": ["phases", "rubric"]
}
